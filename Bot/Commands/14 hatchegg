const { SlashCommandBuilder, ContainerBuilder, SectionBuilder, SeparatorBuilder, TextDisplayBuilder, MessageFlags, EmbedBuilder } = require('discord.js');
const { EGG_CONFIG } = require('../LevelSystem/1activityegg');
const dbManager = require('../Data/database');

module.exports = {
    data: new SlashCommandBuilder()
        .setName('hatch')
        .setDescription('Run the egg hatching ceremony'),

    async execute(interaction) {
        try {
            await interaction.deferReply({ flags: MessageFlags.Ephemeral });

            // ===== Permission Check =====
            const moderateRoleData = await dbManager.getBotSetting('moderateRole');
            if (!moderateRoleData) {
                return interaction.editReply({
                    embeds: [new EmbedBuilder().setColor('#8B0000').setTitle('❌ │ Moderate Role Not Set').setDescription('Use `/setrole` to configure the moderation role first.')]
                });
            }
            const roleInfo = JSON.parse(moderateRoleData.setting_value);
            const executor = await interaction.guild.members.fetch(interaction.user.id);
            if (!executor.roles.cache.has(roleInfo.id)) {
                return interaction.editReply({
                    embeds: [new EmbedBuilder().setColor('#8B0000').setTitle('⛔ │ Permission Denied').setDescription(`This command is only for <@&${roleInfo.id}>.`)]
                });
            }

            if (!global.eggSystem) {
                return interaction.editReply({
                    embeds: [new EmbedBuilder().setColor('#FF4444').setTitle('❌ Egg System Offline')]
                });
            }

            // ===== جلب كل البيضات النشطة =====
            const allEggs = await dbManager.all(
                `SELECT * FROM egg_holders 
                 WHERE hatched = false 
                 ORDER BY heat DESC`
            );

            if (allEggs.length === 0) {
                return interaction.editReply({
                    embeds: [new EmbedBuilder().setColor('#555555').setTitle('🥚 No Active Eggs').setDescription('No community members have active eggs right now.')]
                });
            }

            // ===== TIERS =====
            const thresholds = {
                legendary: 80,
                epic:      70,
                rare:      60,
                uncommon:  50,
                common:    40
            };

            const prizes = {
                legendary: '💵 $15 Gift',
                epic:      '💵 $10 Gift',
                rare:      '💵 $5 Gift',
                uncommon:  '🎮 Game Key',
                common:    '🎮 Game Key'
            };

            const tiers = {
                normal: {
                    legendary: { min: thresholds.legendary, prize: prizes.legendary, label: 'Legendary', color: '#FFD700', eggs: [] },
                    epic:      { min: thresholds.epic,      prize: prizes.epic,      label: 'Epic',      color: '#9B59B6', eggs: [] },
                    rare:      { min: thresholds.rare,      prize: prizes.rare,      label: 'Rare',      color: '#00BFFF', eggs: [] },
                    uncommon:  { min: thresholds.uncommon,  prize: prizes.uncommon,  label: 'Uncommon',  color: '#00FF88', eggs: [] },
                    common:    { min: thresholds.common,    prize: prizes.common,    label: 'Common',    color: '#FFFFFF', eggs: [] }
                },
                special: {
                    legendary: { min: thresholds.legendary, prize: prizes.legendary, label: 'Legendary Spring', color: '#FFA500', eggs: [] },
                    epic:      { min: thresholds.epic,      prize: prizes.epic,      label: 'Epic Spring',      color: '#FF8C00', eggs: [] },
                    rare:      { min: thresholds.rare,      prize: prizes.rare,      label: 'Rare Spring',      color: '#FFA07A', eggs: [] },
                    uncommon:  { min: thresholds.uncommon,  prize: prizes.uncommon,  label: 'Uncommon Spring',  color: '#FFB347', eggs: [] },
                    common:    { min: thresholds.common,    prize: prizes.common,    label: 'Common Spring',    color: '#FFC67E', eggs: [] }
                }
            };

            // توزيع البيضات
            for (const egg of allEggs) {
                const heat = parseFloat(egg.heat) || 0;
                const eggType = egg.egg_type || 'normal';
                const tierConfig = tiers[eggType];
                if (!tierConfig) continue;

                if (heat >= tierConfig.legendary.min) {
                    tierConfig.legendary.eggs.push(egg);
                } else if (heat >= tierConfig.epic.min) {
                    tierConfig.epic.eggs.push(egg);
                } else if (heat >= tierConfig.rare.min) {
                    tierConfig.rare.eggs.push(egg);
                } else if (heat >= tierConfig.uncommon.min) {
                    tierConfig.uncommon.eggs.push(egg);
                } else if (heat >= tierConfig.common.min) {
                    tierConfig.common.eggs.push(egg);
                }
            }

            // اختيار الفائزين
            function selectWinnerWithWeight(eggs, tierMin) {
                if (eggs.length === 0) return null;
                const weightedList = [];
                for (const egg of eggs) {
                    const heat = parseFloat(egg.heat) || 0;
                    const eggType = egg.egg_type || 'normal';
                    let weight = (eggType === 'special') ? 2 : 1;
                    const heatBonus = (heat - tierMin) * 0.1;
                    weight += Math.max(0, heatBonus);
                    const repeatCount = Math.max(1, Math.round(weight));
                    for (let i = 0; i < repeatCount; i++) weightedList.push(egg);
                }
                if (weightedList.length === 0) return null;
                const randomIndex = Math.floor(Math.random() * weightedList.length);
                return weightedList[randomIndex];
            }

            const tierOrder = ['legendary', 'epic', 'rare', 'uncommon', 'common'];
            const winnersMap = new Map();

            for (const tierName of tierOrder) {
                const normalEggs = tiers.normal[tierName].eggs;
                const specialEggs = tiers.special[tierName].eggs;
                const allEggsInTier = [...normalEggs, ...specialEggs];
                if (allEggsInTier.length === 0) continue;

                const winnerEgg = selectWinnerWithWeight(allEggsInTier, thresholds[tierName]);
                if (!winnerEgg) continue;

                const user = await interaction.client.users.fetch(winnerEgg.user_id).catch(() => null);
                const eggType = winnerEgg.egg_type || 'normal';
                const tierData = (eggType === 'special') ? tiers.special[tierName] : tiers.normal[tierName];

                winnersMap.set(tierName, {
                    tier: tierData,
                    egg: winnerEgg,
                    user,
                });

                await dbManager.run(
                    `UPDATE egg_holders SET hatched = true WHERE id = $1`,
                    [winnerEgg.id]
                );
            }

            // ===== بناء الكونتينر =====
            const container = new ContainerBuilder().setAccentColor(0xFFD700);

            // العنوان
            container.addTextDisplayComponents((textDisplay) =>
                textDisplay.setContent(`# 🎉 │ Huge Congratulations To The Winners!`)
            );
            container.addSeparatorComponents((separator) => new SeparatorBuilder().setDivider(true));

            const winnerEmojis = {
                legendary: '🥇',
                epic:      '🥈',
                rare:      '🥉',
                uncommon:  '🏅',
                common:    '🎁'
            };

            // بناء الأقسام بالترتيب الصحيح
            const allSections = [];

            for (const tierName of tierOrder) {
                const winner = winnersMap.get(tierName);
                const capitalizedTier = tierName.charAt(0).toUpperCase() + tierName.slice(1);
                const tierEmoji = winnerEmojis[tierName] || '🏆';

                if (winner) {
                    // فائز موجود
                    const heat = parseFloat(winner.egg.heat) || 0;
                    const heatEmoji = global.eggSystem.getHeatEmoji(heat);
                    const userMention = winner.user ? `<@${winner.egg.user_id}>` : winner.egg.username;

                    let eggTypeEmoji, eggTypeLabel;
                    if (winner.egg.egg_type === 'special') {
                        eggTypeEmoji = '🐰';
                        eggTypeLabel = 'Spring Egg';
                    } else {
                        const colorData = EGG_CONFIG.EGG_COLORS[winner.egg.egg_color] || EGG_CONFIG.EGG_COLORS.green;
                        eggTypeEmoji = colorData.emoji;
                        eggTypeLabel = colorData.label;
                    }

                    let prizeFieldEmoji = '🏆';
                    let prizeText = winner.tier.prize;
                    if (winner.tier.prize.includes('💵')) {
                        prizeFieldEmoji = '💵';
                        prizeText = winner.tier.prize.replace('💵', '').trim();
                    } else if (winner.tier.prize.includes('🎮')) {
                        prizeFieldEmoji = '🗝️';
                        prizeText = winner.tier.prize.replace('🎮', '').trim();
                    }

                    const section = new SectionBuilder()
                        .addTextDisplayComponents(
                            (textDisplay) => textDisplay.setContent(`# ${tierEmoji} ${userMention}`),
                            (textDisplay) => textDisplay.setContent(`### ${prizeFieldEmoji} **Prize:** ${prizeText}`),
                            (textDisplay) => textDisplay.setContent(`-# ${heatEmoji} **Heat:** ${heat.toFixed(2)}% | **${eggTypeLabel}** | Tier: **${capitalizedTier}**`)
                        );

                    const avatarUrl = winner.user
                        ? winner.user.displayAvatarURL({ extension: 'png', size: 256 })
                        : 'https://cdn.discordapp.com/embed/avatars/0.png';
                    section.setThumbnailAccessory((thumbnail) =>
                        thumbnail
                            .setDescription(`${winner.egg.username} - Winner`)
                            .setURL(avatarUrl)
                    );

                    allSections.push(section);
                } else {
                    // لا يوجد فائز – نعرض قالب الـ No Winners مع الجائزة المناسبة
                    const prizeRaw = prizes[tierName];
                    let prizeFieldEmoji = '🏆';
                    let prizeText = prizeRaw;
                    if (prizeRaw.includes('💵')) {
                        prizeFieldEmoji = '💵';
                        prizeText = prizeRaw.replace('💵', '').trim();
                    } else if (prizeRaw.includes('🎮')) {
                        prizeFieldEmoji = '🗝️';
                        prizeText = prizeRaw.replace('🎮', '').trim();
                    }

                    const section = new SectionBuilder()
                        .addTextDisplayComponents(
                            (textDisplay) => textDisplay.setContent(`# ${tierEmoji} No Winner`),
                            (textDisplay) => textDisplay.setContent(`### ${prizeFieldEmoji} **Prize:** ${prizeText}`),
                            (textDisplay) => textDisplay.setContent(`-# 🌡️ **Heat:** – | **Unknown Egg** | Tier: **${capitalizedTier}**`)
                        )
                        .setThumbnailAccessory((thumbnail) =>
                            thumbnail
                                .setDescription(`No Winner - ${capitalizedTier} Tier`)
                                .setURL('https://cdn.discordapp.com/embed/avatars/0.png')
                        );

                    allSections.push(section);
                }
            }

            // إضافة الأقسام إلى الكونتينر مع فواصل بينها
            for (let i = 0; i < allSections.length; i++) {
                container.addSectionComponents((s) => allSections[i]);
                if (i < allSections.length - 1) {
                    container.addSeparatorComponents((separator) => new SeparatorBuilder().setDivider(true));
                }
            }

            // إذا لم يكن هناك أي أقسام (لا يحدث عادةً) نعرض ملخص البيضات
            if (allSections.length === 0) {
                const highestHeat = parseFloat(allEggs[0]?.heat) || 0;
                const normalEggsCount = allEggs.filter(e => e.egg_type !== 'special').length;
                const specialEggsCount = allEggs.filter(e => e.egg_type === 'special').length;

                container.addTextDisplayComponents((textDisplay) =>
                    textDisplay.setContent(`## 📊 Eggs Summary`)
                );
                container.addTextDisplayComponents((textDisplay) =>
                    textDisplay.setContent(`🥚 Total active eggs: **${allEggs.length}**`)
                );
                container.addTextDisplayComponents((textDisplay) =>
                    textDisplay.setContent(`🥚 Normal eggs: **${normalEggsCount}**`)
                );
                container.addTextDisplayComponents((textDisplay) =>
                    textDisplay.setContent(`🐰 Special eggs: **${specialEggsCount}**`)
                );
                container.addTextDisplayComponents((textDisplay) =>
                    textDisplay.setContent(`🌡️ Highest heat: **${highestHeat.toFixed(2)}%**`)
                );
            }

            // إرسال رسالة الحفل إلى القناة
            await interaction.channel.send({
                components: [container],
                flags: MessageFlags.IsComponentsV2,
                allowedMentions: { parse: [] }
            });

            // تأكيد للمستخدم
            await interaction.editReply({
                content: '✅ Hatching ceremony has been broadcast!',
                allowedMentions: { parse: [] }
            });

            // تسجيل النتائج
            console.log(`🐣 [HATCH CEREMONY] by ${interaction.user.tag}`);
            if (winnersMap.size > 0) {
                for (const [tier, w] of winnersMap.entries()) {
                    const heat = parseFloat(w.egg.heat) || 0;
                    console.log(`   🏆 ${w.egg.username} | Tier: ${tier} | Heat: ${heat.toFixed(2)}%`);
                }
            } else {
                console.log(`   ❌ No winners this ceremony | Total eggs: ${allEggs.length} | Highest heat: ${parseFloat(allEggs[0]?.heat || 0).toFixed(2)}%`);
            }

        } catch (error) {
            console.error('❌ /hatch error:', error);
            if (interaction.deferred || interaction.replied) {
                await interaction.editReply({ content: '❌ Error running hatch ceremony' });
            } else {
                await interaction.reply({ content: '❌ Error running hatch ceremony', ephemeral: true });
            }
        }
    }
};
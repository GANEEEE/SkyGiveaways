const {
    SlashCommandBuilder,
    ContainerBuilder,
    SectionBuilder,
    SeparatorBuilder,
    TextDisplayBuilder,
    MessageFlags
} = require('discord.js');
const { EGG_CONFIG } = require('../LevelSystem/1activityegg');

module.exports = {
    data: new SlashCommandBuilder()
        .setName('eggstatus')
        .setDescription('Check your current egg status'),

    async execute(interaction) {
        try {
            await interaction.deferReply({ ephemeral: false });

            const userId = interaction.user.id;

            if (!global.eggSystem) {
                return interaction.editReply({
                    content: '❌ The egg system is not active right now.'
                });
            }

            const eggs = await global.eggSystem.getUserEgg(userId);

            if (!eggs || eggs.length === 0) {
                const container = new ContainerBuilder()
                    .setAccentColor(0x0073ff)
                    .addTextDisplayComponents((t) =>
                        t.setContent(
                            `## 🥚 │ No Egg Found!\n` +
                            `You don't have an egg yet!\n\n` +
                            `* Keep an eye on <#${EGG_CONFIG.DROP_CHANNEL_ID}>\n` +
                            `* When an egg drops, click **Collect** fast!`
                        )
                    );

                return interaction.editReply({
                    components: [container],
                    flags: MessageFlags.IsComponentsV2,
                    allowedMentions: { parse: [] }
                });
            }

            // ===== بناء الـ Container =====
            const hasSpecial = eggs.some(egg => egg.egg_type === 'special');
            const firstEgg   = eggs[0];
            const firstColor = EGG_CONFIG.EGG_COLORS[firstEgg.egg_color];

            // تحويل الـ hex color لـ integer
            const accentColor = firstColor
                ? parseInt(firstColor.embedColor.replace('#', ''), 16)
                : 0x00FF88;

            const container = new ContainerBuilder().setAccentColor(accentColor);

            // ===== العنوان =====
            const title = hasSpecial ? '🐰 │ Your Spring Egg Status' : '🥚 │ Your Egg Status';
            container.addTextDisplayComponents((t) => t.setContent(`## ${title}`));
            container.addSeparatorComponents((s) => s.setDivider(true));

            // ===== كل بيضة =====
            for (let i = 0; i < eggs.length; i++) {
                const egg       = eggs[i];
                const isSpecial = egg.egg_type === 'special';
                const colorData = EGG_CONFIG.EGG_COLORS[egg.egg_color];
                if (!colorData) continue;

                const heat      = parseFloat(egg.heat) || 0;
                const tier      = global.eggSystem.getHeatTier(heat);
                const heatEmoji = global.eggSystem.getHeatEmoji(heat);

                // ✅ التحقق من الوصول إلى 100%
                const isFullyHeated = heat >= 100;

                // استخراج إيموجي ونص الـ tier
                const tierParts = tier.label.split(' ');
                const tierEmoji = tierParts[0];
                const tierText  = tierParts.slice(1).join(' ');

                // Progress bar
                const heatCapped = Math.min(heat, 100);
                const filled     = Math.floor(heatCapped / 10);
                const empty      = 10 - filled;
                const progressBar = '█'.repeat(filled) + '░'.repeat(empty);

                // ✅ عدد الرسائل المطلوب حسب نوع البيضة
                const msgsPerHeat = isSpecial 
                    ? EGG_CONFIG.SPECIAL_MSG_PER_HEAT   // 15
                    : EGG_CONFIG.USER_MSG_PER_HEAT;     // 20

                const msgsLeft = msgsPerHeat - (egg.msg_counter || 0);

                // Next milestone - فقط إذا لم تكن 100%
                const nextMilestone = !isFullyHeated 
                    ? EGG_CONFIG.MILESTONES.find(m => m > heat) 
                    : null;

                const msgsToMilestone = nextMilestone && !isFullyHeated
                    ? ((nextMilestone - heat) * msgsPerHeat) + (msgsPerHeat - msgsLeft)
                    : null;

                // فاصل بين البيض
                if (i > 0) {
                    container.addSeparatorComponents((s) => s.setDivider(true));
                }

                // ===== بناء النص =====
                const eggEmoji  = isSpecial ? '🐰' : colorData.emoji;
                const eggLabel  = isSpecial ? 'Spring Egg' : colorData.label;

                let heatSectionText = '';
                let nextSectionText = '';

                // ✅ قسم الحرارة
                heatSectionText = `${heatEmoji} │ **Heat**\n` +
                    `\`${progressBar}\` \`${heat.toFixed(2)}%\`\n\n` +
                    `${tierEmoji} │ **Current Tier**\n` +
                    `${tierText}\n\n`;

                // ✅ قسم الرسائل المتبقية أو رسالة الجاهزية
                if (isFullyHeated) {
                    // عند 100% - إظهار أن البيضة جاهزة
                    nextSectionText = `🎉 │ **Ready to Hatch!**\n` +
                        `Your egg is fully heated and ready for the next ceremony!\n` +
                        `-# Use \`/hatch\` to run the ceremony when enough eggs are ready.`;
                } else {
                    // العادي - إظهار عدد الرسائل المتبقية
                    const milestoneText = nextMilestone 
                        ? `**${nextMilestone}%** in **${Math.max(0, Math.ceil(msgsToMilestone))}** messages`
                        : '### ✅ All milestones reached!';

                    nextSectionText = `💬 │ **Next Heat Up**\n` +
                        `${msgsLeft} messages\n\n` +
                        `🎯 │ **Next Milestone**\n` +
                        `${milestoneText}`;
                }

                const section = new SectionBuilder()
                    .addTextDisplayComponents((t) => t.setContent(heatSectionText + nextSectionText))
                    .setThumbnailAccessory((thumb) =>
                        thumb
                            .setDescription(`${eggEmoji} ${eggLabel}`)
                            .setURL(interaction.user.displayAvatarURL({ extension: 'png', size: 256 }))
                    );

                container.addSectionComponents((s) => section);
            }

            return interaction.editReply({
                components: [container],
                flags: MessageFlags.IsComponentsV2,
                allowedMentions: { parse: [] }
            });

        } catch (error) {
            console.error('❌ /eggstatus error:', error);
            await interaction.editReply({ content: '❌ Error fetching egg status.' });
        }
    }
};
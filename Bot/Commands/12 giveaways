    // ========== ENDED GIVEAWAY MESSAGE ==========
    createEndedGiveawayMessage(gameName, gameLink, platform, imageUrl, note, hostId, participantsCount, winnersCount, giveawayCode, messageReqType, messageReqAmount, confirmCount = 0, declineCount = 0, winners = [], coDeMembers = []) {
        const safeGameLink = gameLink || 'https://store.steampowered.com';

        let mainContent = `## **${gameName}** | **${platform}**\n\n`;
        mainContent += `Participants: **${participantsCount}**\n`;
        mainContent += `Winners: **${winnersCount}**\n`;
        mainContent += `Game Link: **[${gameName}](${safeGameLink})**\n\n`;

        if (note) mainContent += `Note: ${note}\n`;

        if (messageReqType && messageReqAmount) {
            const typeNames = { total: 'Total', monthly: 'Monthly', weekly: 'Weekly', daily: 'Daily' };
            mainContent += `Required Messages: **${messageReqAmount}+ ${typeNames[messageReqType]}**\n`;
        }

        mainContent += `Host: <@${hostId}> | ID: \`${giveawayCode}\``;

        const winnerStatusMap = new Map();
        for (const winner of winners) {
            winnerStatusMap.set(winner, '⌛');
        }
        for (const member of coDeMembers) {
            if (member && member.user_id && winners.includes(member.user_id)) {
                winnerStatusMap.set(member.user_id, member.status === 'confirm' ? '✅' : '❌');
            }
        }

        let winnersContent = '';
        let secondContainerComponents = [];

        if (participantsCount === 0) {
            winnersContent = `## 😕 No Participants\nUnfortunately, no one joined this giveaway`;
            secondContainerComponents = [
                { type: 10, content: winnersContent }
            ];
        } else {
            if (winnersCount === 1) {
                const winner = winners[0] || 'Unknown';
                const status = winnerStatusMap.get(winner) || '⌛';
                winnersContent = `## ${status} Congratulations To <@${winner}>\nYou won **${gameName}**, please contact with <@${hostId}>\n\n-# Press Confirm if the key worked, otherwise press Decline`;
            } else {
                const winnersWithStatus = winners.map(id => {
                    const status = winnerStatusMap.get(id) || '⌛';
                    return `<@${id}> ${status}`;
                }).join(' - ');

                winnersContent = `## 🎉 Congratulations To Winners!\n${winnersWithStatus}\nYou won **${gameName}**, please contact with <@${hostId}>\n\n-# Press Confirm if the key worked, otherwise press Decline`;
            }

            secondContainerComponents = [
                { type: 10, content: winnersContent },
                {
                    type: 1,
                    components: [
                        { type: 2, style: 3, custom_id: `giveaway_confirm_${giveawayCode}`, label: `Confirm (${confirmCount}/${winnersCount})` },
                        { type: 2, style: 4, custom_id: `giveaway_decline_${giveawayCode}`, label: `Decline (${declineCount}/${winnersCount})` }
                    ]
                }
            ];
        }

        return {
            components: [
                {
                    type: 17,
                    accent_color: 0x0073ff,
                    spoiler: false,
                    components: [
                        { type: 10, content: mainContent },
                        {
                            type: 12,
                            items: [{ media: { url: imageUrl }, description: null, spoiler: false }]
                        }
                    ]
                },
                {
                    type: 17,
                    accent_color: 0x0073ff,
                    spoiler: false,
                    components: secondContainerComponents
                }
            ],
            flags: 32768,
            allowedMentions: { parse: ['users'] }
        };
    },

    // ========== UPDATE CONFIRM BUTTONS ==========
    updateConfirmButtons(message, giveawayCode, confirmCount, declineCount, totalWinners) {
        try {
            const oldComponents = message.components;
            const newComponents = JSON.parse(JSON.stringify(oldComponents));

            if (newComponents[1] && 
                newComponents[1].components && 
                newComponents[1].components[1] && 
                newComponents[1].components[1].components) {

                newComponents[1].components[1].components[0].label = `Confirm (${confirmCount}/${totalWinners})`;
                newComponents[1].components[1].components[1].label = `Decline (${declineCount}/${totalWinners})`;
            }

            return newComponents;
        } catch (error) {
            console.error('Error updating confirm buttons:', error);
            return message.components;
        }
    },

    // ========== JOIN COLLECTOR ==========
    setupJoinCollector(message, giveawayCode, endsAt, winnersCount, client, giveawayData) {
        const filter = (i) => {
            return i.customId === `giveaway_join_${giveawayCode}`;
        };

        const timeRemaining = endsAt.getTime() - Date.now();

        const collector = message.createMessageComponentCollector({ 
            filter, 
            time: timeRemaining
        });

        collector.on('collect', async (i) => {
            try {
                if (!i.deferred && !i.replied) {
                    await i.deferReply({ ephemeral: true });
                }

                const giveaway = await dbManager.getActiveGiveawayByCode(giveawayCode);
                if (!giveaway) {
                    return await i.editReply({ 
                        content: '❌ This giveaway no longer exists',
                        allowedMentions: { parse: [] }
                    });
                }

                const participants = giveaway.participants || [];
                const isParticipant = participants.includes(i.user.id);

                if (!isParticipant && giveawayData.messageReqType && giveawayData.messageReqAmount) {
                    const userStats = await dbManager.getUserMessageStats(i.user.id, giveawayData.messageReqType);
                    if (!userStats || userStats.total < giveawayData.messageReqAmount) {
                        const typeNames = {
                            total: 'Total',
                            monthly: 'Monthly',
                            weekly: 'Weekly',
                            daily: 'Daily'
                        };
                        return await i.editReply({ 
                            content: `❌ You need **${giveawayData.messageReqAmount}+ ${typeNames[giveawayData.messageReqType]} Messages** to join!\nYour ${typeNames[giveawayData.messageReqType]}: **${userStats?.total || 0}**`,
                            allowedMentions: { parse: [] }
                        });
                    }
                }

                if (isParticipant) {
                    const result = await dbManager.removeParticipant(giveawayCode, i.user.id);
                    if (result.success) {
                        const updatedMessage = this.updateGiveawayMessage(
                            giveawayData.gameName,
                            giveawayData.gameLink,
                            giveawayData.platform,
                            endsAt,
                            winnersCount,
                            giveawayData.note,
                            giveawayData.reqRoleId,
                            giveawayData.imageUrl,
                            giveawayCode,
                            giveawayData.hostId,
                            result.participantsCount,
                            giveawayData.messageReqType,
                            giveawayData.messageReqAmount
                        );
                        await message.edit(updatedMessage);
                        await i.editReply({ 
                            content: '✅ You left the giveaway',
                            allowedMentions: { parse: [] }
                        });
                    }
                } else {
                    if (giveaway.req_role_id && !i.member.roles.cache.has(giveaway.req_role_id)) {
                        return await i.editReply({ 
                            content: `❌ You need <@&${giveaway.req_role_id}> to join this giveaway`,
                            allowedMentions: { parse: [] }
                        });
                    }

                    const result = await dbManager.addParticipant(giveawayCode, i.user.id, i.user.username);
                    if (result.success) {
                        const updatedMessage = this.updateGiveawayMessage(
                            giveawayData.gameName,
                            giveawayData.gameLink,
                            giveawayData.platform,
                            endsAt,
                            winnersCount,
                            giveawayData.note,
                            giveawayData.reqRoleId,
                            giveawayData.imageUrl,
                            giveawayCode,
                            giveawayData.hostId,
                            result.participantsCount,
                            giveawayData.messageReqType,
                            giveawayData.messageReqAmount
                        );
                        await message.edit(updatedMessage);
                        await i.editReply({ 
                            content: '✅ You joined the giveaway, good luck!',
                            allowedMentions: { parse: [] }
                        });
                    }
                }
            } catch (error) {
                console.error('Error in join collector:', error);
            }
        });

        collector.on('end', async () => {
            await this.handleGiveawayEnd(message, giveawayCode, client, giveawayData);
        });
    },

    // ========== HANDLE GIVEAWAY END ==========
    async handleGiveawayEnd(message, giveawayCode, client, giveawayData) {
        try {
            const giveaway = await dbManager.getActiveGiveawayByCode(giveawayCode);
            if (!giveaway) return;

            const confirmationStatus = await dbManager.getGiveawayConfirmationStatus(giveawayCode);
            const coDeMembers = confirmationStatus?.coDeMembers || [];

            const result = await dbManager.endGiveaway(giveawayCode);
            if (!result.success) return;

            if (result.noParticipants) {
                const endedMessage = this.createEndedGiveawayMessage(
                    giveawayData.gameName,
                    giveawayData.gameLink,
                    giveawayData.platform,
                    giveawayData.imageUrl,
                    giveawayData.note,
                    giveawayData.hostId,
                    0,
                    giveaway.winners_count,
                    giveawayCode,
                    giveawayData.messageReqType,
                    giveawayData.messageReqAmount,
                    0,
                    0,
                    [],
                    coDeMembers
                );
                await message.edit(endedMessage);
                return;
            }

            const actualWinnersCount = result.winners ? result.winners.length : 0;
            const winners = result.winners || [];

            for (const winnerId of winners) {
                try {
                    const member = await message.guild.members.fetch(winnerId);
                    await member.roles.add(WINNER_ROLE_ID);
                } catch (roleError) {
                    console.error(`Error giving winner role to ${winnerId}:`, roleError);
                }
            }

            const endedMessage = this.createEndedGiveawayMessage(
                giveawayData.gameName,
                giveawayData.gameLink,
                giveawayData.platform,
                giveawayData.imageUrl,
                giveawayData.note,
                giveawayData.hostId,
                result.participantsCount || 0,
                actualWinnersCount,
                giveawayCode,
                giveawayData.messageReqType,
                giveawayData.messageReqAmount,
                0,
                0,
                winners,
                coDeMembers
            );
            await message.edit(endedMessage);

        } catch (error) {
            console.error('Error handling giveaway end:', error);
        }
    },

    // ========== CONFIRM COLLECTOR ==========
    setupConfirmCollector(message, giveawayCode, client) {
        const filter = (i) => {
            return i.customId === `giveaway_confirm_${giveawayCode}` || 
                   i.customId === `giveaway_decline_${giveawayCode}`;
        };

        const collector = message.createMessageComponentCollector({ 
            filter,
            time: null
        });

        collector.on('collect', async (i) => {
            try {
                await i.deferReply({ ephemeral: true });

                const action = i.customId.includes('confirm') ? 'confirm' : 'decline';

                const result = await dbManager.updateWinnerStatus(giveawayCode, i.user.id, action);

                if (!result.success) {
                    if (result.code === 'NOT_WINNER') {
                        await i.editReply({ 
                            content: '❌ This button is for winners only!',
                            allowedMentions: { parse: [] }
                        });
                    } else if (result.code === 'ALREADY_VOTED') {
                        await i.editReply({ 
                            content: '❌ You have already voted!',
                            allowedMentions: { parse: [] }
                        });
                    } else {
                        await i.editReply({ 
                            content: `❌ ${result.error}`,
                            allowedMentions: { parse: [] }
                        });
                    }
                    return;
                }

                const updatedConfirmation = await dbManager.getGiveawayConfirmationStatus(giveawayCode);
                const updatedCoDeMembers = updatedConfirmation?.coDeMembers || [];

                const updatedGiveaway = await dbManager.getGiveawayByCode(giveawayCode);
                const updatedWinners = updatedGiveaway?.winners || [];

                const giveawayCommand = client.commands.get('giveaway');
                const updatedMessage = giveawayCommand.createEndedGiveawayMessage(
                    updatedGiveaway.game_name,
                    updatedGiveaway.game_link,
                    updatedGiveaway.platform,
                    updatedGiveaway.image_url,
                    updatedGiveaway.note,
                    updatedGiveaway.host_id,
                    updatedGiveaway.participants?.length || 0,
                    updatedWinners.length,
                    giveawayCode,
                    updatedGiveaway.message_req_type,
                    updatedGiveaway.message_req_amount,
                    updatedConfirmation.confirmCount || 0,
                    updatedConfirmation.declineCount || 0,
                    updatedWinners,
                    updatedCoDeMembers
                );

                await message.edit(updatedMessage);

                await i.editReply({ 
                    content: `✅ You have ${action === 'confirm' ? 'confirmed' : 'declined'} your prize!`,
                    allowedMentions: { parse: [] }
                });

                if (result.data.allResponded) {
                    await this.handleAllResponded(message, giveawayCode, result.data, updatedWinners.length);
                }

            } catch (error) {
                console.error('Error in confirm collector:', error);
                await i.editReply({ 
                    content: '❌ An error occurred',
                    allowedMentions: { parse: [] }
                }).catch(() => {});
            }
        });
    },

    // ========== HANDLE ALL RESPONDED ==========
    async handleAllResponded(message, giveawayCode, data, actualWinnersCount) {
        try {
            const giveaway = await dbManager.getGiveawayByCode(giveawayCode);

            if (data.allConfirmed) {
                await dbManager.rewardHost(giveawayCode, giveaway.host_id);

                const rewardMessage = {
                    components: [
                        {
                            type: 17,
                            accent_color: 0x0073ff,
                            spoiler: false,
                            components: [
                                {
                                    type: 10,
                                    content: `### ✅ All ${actualWinnersCount} winners confirmed!\n<@${giveaway.host_id}> received 250 XP and 150 Coins!`
                                }
                            ]
                        }
                    ],
                    flags: 32768,
                    allowedMentions: { parse: ['users'] }
                };

                await message.channel.send(rewardMessage);
            }

        } catch (error) {
            console.error('Error handling all responded:', error);
        }
    },

    // ========== GENERATE GIVEAWAY CODE ==========
    generateGiveawayCode() {
        let code = '';
        for (let i = 0; i < 8; i++) {
            code += Math.floor(Math.random() * 10);
        }
        return `GIV-${code}`;
    }
};
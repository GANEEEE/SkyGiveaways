const { 
    SlashCommandBuilder
} = require('discord.js');
const dbManager = require('../Data/database');

// Constants
const WINNER_ROLE_ID = '1395730680926965781';

module.exports = {
    data: new SlashCommandBuilder()
        .setName('giveawayreroll')
        .setDescription('Reroll giveaway winners')
        .addStringOption(option =>
            option.setName('giveaway_id')
                .setDescription('The giveaway code or message ID')
                .setRequired(true))
        .addIntegerOption(option =>
            option.setName('count')
                .setDescription('Number of winners to reroll')
                .setRequired(true)
                .setMinValue(1)
                .setMaxValue(25))
        .addBooleanOption(option =>
            option.setName('include_old')
                .setDescription('Include previous winners in the reroll?')
                .setRequired(true)),

    async execute(interaction) {
        try {
            await interaction.deferReply({ ephemeral: true });

            // ✅ نفس التحقق بالضبط زي reset
            const moderateRoleData = await dbManager.getBotSetting('moderateRole');

            if (!moderateRoleData) {
                return interaction.editReply({ 
                    content: '❌ Moderate Role Not Set\nModeration role not assigned, Please configure the role to enable moderation features by `/setrole`',
                    allowedMentions: { parse: [] }
                });
            }

            const roleInfo = JSON.parse(moderateRoleData.setting_value);
            const member = await interaction.guild.members.fetch(interaction.user.id);
            const hasModerateRole = member.roles.cache.has(roleInfo.id);

            if (!hasModerateRole) {
                return interaction.editReply({ 
                    content: `⛔ Permission Denied\nThis command is available only for <@&${roleInfo.id}>.`,
                    allowedMentions: { parse: [] }
                });
            }

            // باقي الكود...
            const giveawayId = interaction.options.getString('giveaway_id');
            const count = interaction.options.getInteger('count');
            const includeOld = interaction.options.getBoolean('include_old');

            // البحث عن الجيفاواي
            let giveaway = await dbManager.getGiveawayByCode(giveawayId);
            if (!giveaway) {
                giveaway = await dbManager.getGiveawayByMessage(giveawayId);
            }

            if (!giveaway) {
                return await interaction.editReply({ 
                    content: '❌ Giveaway not found!\nPlease provide a valid giveaway code or message ID',
                    allowedMentions: { parse: [] }
                });
            }

            if (!giveaway.is_ended) {
                return await interaction.editReply({ 
                    content: '❌ Giveaway is still active!\nYou can only reroll ended giveaways',
                    allowedMentions: { parse: [] }
                });
            }

            const participants = giveaway.participants || [];

            if (participants.length === 0) {
                return await interaction.editReply({ 
                    content: '❌ No participants!\nThis giveaway has no participants to reroll',
                    allowedMentions: { parse: [] }
                });
            }

            // جلب الرسالة الأصلية (عشان نعدل عليها)
            let message;
            try {
                const channel = await interaction.client.channels.fetch(giveaway.channel_id);
                message = await channel.messages.fetch(giveaway.message_id);
            } catch (error) {
                console.error('Error fetching giveaway message:', error);
                return await interaction.editReply({ 
                    content: '❌ Could not find the giveaway message!\nIt may have been deleted',
                    allowedMentions: { parse: [] }
                });
            }

            // تنفيذ الـ reroll
            await this.executeReroll(interaction, giveaway, participants, count, includeOld, message);

        } catch (error) {
            console.error('Error in giveawayreroll command:', error);
            await interaction.editReply({ 
                content: '❌ An error occurred while executing the command',
                allowedMentions: { parse: [] }
            });
        }
    },

    async executeReroll(interaction, giveaway, participants, count, includeOld, message) {
        try {
            // جلب الـ co_de_members عشان نعرف مين اللي أكد أو رفض
            const confirmationStatus = await dbManager.getGiveawayConfirmationStatus(giveaway.giveaway_code);
            const confirmedMembers = confirmationStatus?.coDeMembers || [];

            // جلب الـ winners الحاليين
            const currentWinners = giveaway.winners || [];

            // تحديد المشاركين المحميين (اللي في co_de_members سواء confirm أو decline)
            const protectedMembers = confirmedMembers.map(m => m.user_id);

            // تحديد الفائزين المحميين (اللي في winners ومحميين)
            const protectedWinners = currentWinners.filter(id => protectedMembers.includes(id));

            // تحديد الفائزين اللي ممكن يتغيروا (اللي في winners بس مش محميين)
            const changeableWinners = currentWinners.filter(id => !protectedMembers.includes(id));

            // تحديد المشاركين المؤهلين للـ reroll (كل المشاركين ما عدا المحميين)
            let eligibleParticipants = participants.filter(id => !protectedMembers.includes(id));

            // لو مش عايز نضم الـ winners القدامى
            if (!includeOld) {
                // نستبعد الـ winners القدامى اللي مش محميين
                eligibleParticipants = eligibleParticipants.filter(id => !changeableWinners.includes(id));
            }

            if (eligibleParticipants.length === 0) {
                return await interaction.editReply({ 
                    content: '⚠️ No eligible participants!\nAll participants have already confirmed or declined their prizes',
                    allowedMentions: { parse: [] }
                });
            }

            // تحديد عدد اللي هنغيرهم = أقل من (عدد changeableWinners أو count)
            const rerollCount = Math.min(changeableWinners.length, count);

            if (rerollCount === 0) {
                return await interaction.editReply({ 
                    content: '⚠️ No winners to reroll!\nAll winners have already confirmed or declined',
                    allowedMentions: { parse: [] }
                });
            }

            // خلط القائمة واختيار الفائزين الجدد
            const shuffled = [...eligibleParticipants].sort(() => 0.5 - Math.random());
            const newWinners = shuffled.slice(0, rerollCount);

            // بناء قائمة الفائزين النهائية:
            // 1. نبدأ بالفائزين المحميين
            // 2. نضيف الفائزين الجدد (في نفس مراكز اللي اتعملهم reroll)
            const finalWinners = [...protectedWinners];

            // نضيف الفائزين الجدد واحد واحد
            for (let i = 0; i < rerollCount; i++) {
                finalWinners.push(newWinners[i]);
            }

            // نضيف أي winners قديمين مش محميين ومش متغيرين (لو includeOld = true)
            if (includeOld) {
                const unchangedOldWinners = changeableWinners.filter(w => !newWinners.includes(w));
                for (let i = 0; i < unchangedOldWinners.length; i++) {
                    finalWinners.push(unchangedOldWinners[i]);
                }
            }

            // تحديث قاعدة البيانات
            await dbManager.updateGiveawayMultipleWinners(giveaway.giveaway_code, finalWinners);

            // إعادة تعيين حالة التأكيد للفائزين الجدد (نمسحهم من co_de_members)
            await this.resetConfirmationForNewWinners(giveaway.giveaway_code, newWinners);

            // منح الرول للفائزين الجدد
            for (const winnerId of newWinners) {
                try {
                    const member = await message.guild.members.fetch(winnerId);
                    await member.roles.add(WINNER_ROLE_ID);
                } catch (roleError) {
                    console.error(`Error giving winner role to ${winnerId}:`, roleError);
                }
            }

            // سحب الرول من الفائزين اللي اتغيروا
            const removedWinners = changeableWinners.filter(w => !newWinners.includes(w) && !includeOld);
            for (const winnerId of removedWinners) {
                try {
                    const member = await message.guild.members.fetch(winnerId);
                    await member.roles.remove(WINNER_ROLE_ID);
                } catch (roleError) {
                    console.error(`Error removing winner role from ${winnerId}:`, roleError);
                }
            }

            // تحديث الرسالة الأصلية (نفس الرسالة)
            await this.updateOriginalMessage(message, giveaway, finalWinners, protectedWinners);

            // رسالة نجاح للمود فقط (ephemeral) - رسالة عادية بدون components
            await interaction.editReply({ 
                content: `✅ Reroll Successful!\nReplaced ${rerollCount} winner(s) with new winners\nProtected ${protectedWinners.length} winner(s) who already confirmed`,
                allowedMentions: { parse: [] }
            });

        } catch (error) {
            console.error('Error executing reroll:', error);
            throw error;
        }
    },

    async resetConfirmationForNewWinners(giveawayCode, newWinners) {
        try {
            // نجيب حالة التأكيد الحالية
            const confirmationStatus = await dbManager.getGiveawayConfirmationStatus(giveawayCode);
            let coDeMembers = confirmationStatus?.coDeMembers || [];

            // نشيل أي entries للفائزين الجدد (عشان هم لسه مأكدوش)
            coDeMembers = coDeMembers.filter(m => !newWinners.includes(m.user_id));

            // نحسب العدادات الجديدة
            const confirmCount = coDeMembers.filter(m => m.status === 'confirm').length;
            const declineCount = coDeMembers.filter(m => m.status === 'decline').length;
            const allResponded = false; // لأن الفائزين الجدد لسه ماردوش
            const allConfirmed = false;

            // نحدث قاعدة البيانات
            const client = await dbManager.pool.connect();
            try {
                await client.query(
                    `UPDATE giveaways 
                     SET co_de_members = $1::jsonb,
                         confirm_count = $2,
                         decline_count = $3,
                         all_responded = $4,
                         all_confirmed = $5,
                         updated_at = CURRENT_TIMESTAMP
                     WHERE giveaway_code = $6`,
                    [JSON.stringify(coDeMembers), confirmCount, declineCount, allResponded, allConfirmed, giveawayCode]
                );
            } finally {
                client.release();
            }

        } catch (error) {
            console.error('Error resetting confirmation for new winners:', error);
        }
    },

    async updateOriginalMessage(message, giveaway, finalWinners, protectedWinners) {
        try {
            // نجيب عدد الـ confirm الحالي
            const confirmationStatus = await dbManager.getGiveawayConfirmationStatus(giveaway.giveaway_code);
            const coDeMembers = confirmationStatus?.coDeMembers || [];
            const confirmCount = confirmationStatus?.confirmCount || 0;
            const declineCount = confirmationStatus?.declineCount || 0;

            // نبني رسالة الجيفاواي المنتهية من أمر الجيفاواي
            const giveawayCommand = message.client.commands.get('giveaway');

            const endedMessage = giveawayCommand.createEndedGiveawayMessage(
                giveaway.game_name,
                giveaway.game_link,
                giveaway.platform,
                giveaway.image_url,
                giveaway.note,
                giveaway.host_id,
                giveaway.participants?.length || 0,
                finalWinners.length,
                giveaway.giveaway_code,
                giveaway.message_req_type,
                giveaway.message_req_amount,
                confirmCount,
                declineCount,
                finalWinners,
                coDeMembers
            );

            await message.edit(endedMessage);
        } catch (error) {
            console.error('Error updating original message:', error);
        }
    }
};